<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBrush" Color="#03050B" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#0D1728" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#16243A" />
    <SolidColorBrush x:Key="BorderBrush" Color="#8EC8FF" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F5F7FB" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#C7D1E8" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#AAB6CE" />
    <SolidColorBrush x:Key="AccentBrush" Color="#5DFF92" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#193F3B" />
    <SolidColorBrush x:Key="AccentCyanBrush" Color="#7DEBFF" />
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#9CD4FF" />
    <SolidColorBrush x:Key="PremiumLineBrush" Color="#C79CD4FF" />
    <SolidColorBrush x:Key="PremiumGlowBrush" Color="#7DEBFF" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#3BA55C" />
    <SolidColorBrush x:Key="DangerBrush" Color="#ED4245" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FAA61A" />

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="CommandButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="#78101D31" />
        <Setter Property="BorderBrush" Value="#C49CD4FF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="17,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="28"
                                              Direction="270"
                                              Opacity="0.42"
                                              ShadowDepth="0"
                                              Color="#73E8FF" />
                        </Border.Effect>
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="#A31B3B58" />
                            <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentCyanBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="UpdateCheckButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="#8E102236" />
        <Setter Property="BorderBrush" Value="#E87DEBFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#9E12253C" Offset="0" />
                                <GradientStop Color="#A51B4A58" Offset="0.55" />
                                <GradientStop Color="#7A173224" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="32"
                                              Direction="270"
                                              Opacity="0.62"
                                              ShadowDepth="0"
                                              Color="#7DEBFF" />
                        </Border.Effect>
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="#F55DFF92" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="#F5F7FB" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Opacity"
                                    Value="0.86" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryCommandButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="#E65DFF92" />
        <Setter Property="BorderBrush" Value="#F57DEBFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="18,9" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="22"
                                              Direction="270"
                                              Opacity="0.56"
                                              ShadowDepth="0"
                                              Color="#5DFF92" />
                        </Border.Effect>
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="#F57DEBFF" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="White" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerCommandButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="#70241422" />
        <Setter Property="BorderBrush" Value="#C8FF6872" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="17,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24"
                                              Direction="270"
                                              Opacity="0.32"
                                              ShadowDepth="0"
                                              Color="#ED4245" />
                        </Border.Effect>
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="#82351A22" />
                            <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="{StaticResource DangerBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="#F5F7FB" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InstallUpdateButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="#06110C" />
        <Setter Property="Background" Value="#F65DFF92" />
        <Setter Property="BorderBrush" Value="#F97DEBFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="18,9" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="34"
                                              Direction="270"
                                              Opacity="0.92"
                                              ShadowDepth="0"
                                              Color="#5DFF92" />
                        </Border.Effect>
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="#FC7DEBFF" />
                            <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="#F5F7FB" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="#F5F7FB" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StageProgressStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="11" />
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="100" />
        <Setter Property="Background" Value="#56101D31" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid x:Name="TemplateRoot"
                          SnapsToDevicePixels="True">
                        <Border CornerRadius="5.5"
                                BorderBrush="#459CD4FF"
                                BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#80101D31" Offset="0" />
                                    <GradientStop Color="#66203542" Offset="0.5" />
                                    <GradientStop Color="#50101D31" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Grid x:Name="PART_Track"
                              ClipToBounds="True">
                            <Grid x:Name="PART_Indicator"
                                  HorizontalAlignment="Left"
                                  ClipToBounds="True">
                                <Border Background="{TemplateBinding Foreground}"
                                        CornerRadius="5.5" />
                                <Border CornerRadius="5.5"
                                        Opacity="0.5">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00FFFFFF" Offset="0" />
                                            <GradientStop Color="#CC7DEBFF" Offset="0.54" />
                                            <GradientStop Color="#F55DFF92" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border Width="22"
                                        HorizontalAlignment="Right"
                                        CornerRadius="5.5"
                                        Background="#C8F5F7FB"
                                        Opacity="0.42" />
                                <Grid.Effect>
                                    <DropShadowEffect BlurRadius="14"
                                                      Direction="270"
                                                      Opacity="0.86"
                                                      ShadowDepth="0"
                                                      Color="#7DEBFF" />
                                </Grid.Effect>
                            </Grid>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BrowserSwitchStyle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="58" Height="32">
                        <Border x:Name="Track"
                                CornerRadius="16"
                                Background="#80101D31"
                                BorderBrush="#C49CD4FF"
                                BorderThickness="1" />
                        <Ellipse x:Name="Knob"
                                 Width="24"
                                 Height="24"
                                 Margin="4"
                                 HorizontalAlignment="Left"
                                 Fill="#D7E4F5">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  Direction="270"
                                                  Opacity="0.5"
                                                  ShadowDepth="0"
                                                  Color="#7DEBFF" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track"
                                    Property="Background"
                                    Value="#B01D4F43" />
                            <Setter TargetName="Track"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Knob"
                                    Property="HorizontalAlignment"
                                    Value="Right" />
                            <Setter TargetName="Knob"
                                    Property="Fill"
                                    Value="{StaticResource AccentCyanBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Track"
                                    Property="BorderThickness"
                                    Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.48" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
