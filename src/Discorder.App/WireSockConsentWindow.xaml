<Window x:Class="Discorder.App.WireSockConsentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WireSock kurulumu"
        Width="540"
        Height="590"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="İlk kurulum gerekiyor" />
            <TextBlock x:Name="VersionText"
                       Margin="0,7,0,0"
                       FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,24,0,0"
                Padding="18"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Text="Kurulum akışı" />
                <TextBlock Margin="0,10,0,0"
                           FontSize="13"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           LineHeight="21"
                           Text="Discorder resmi WireSock VPN Client x64 MSI kurucusunu indirir; SHA-256, Windows Authenticode, yayıncı ve sürüm bilgilerini doğrular. Ardından Windows yönetici onayıyla resmi kurucuyu açar ve kurulum bitince Discord uygulaması için profili otomatik hazırlar. Tarayıcı modu açıksa desteklenen tarayıcılar da profile eklenir." />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock FontSize="14"
                       FontWeight="SemiBold"
                       Text="Kullanım koşulları" />
            <TextBlock Margin="0,9,0,0"
                       FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       TextWrapping="Wrap"
                       LineHeight="21"
                       Text="WireSock ayrı bir üçüncü taraf ürünüdür; ticari veya kurumsal kullanım uygun bir lisans gerektirebilir. Devam edildiğinde Cloudflare WARP hesabı oluşturulur ve wgcf, Cloudflare WARP koşullarını kabul ederek profili üretir. İki hizmetin güncel koşullarını incelemek ve uygun kullanım hakkına sahip olmak kullanıcının sorumluluğundadır." />
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,26,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource CommandButtonStyle}"
                    Content="Lisansı aç"
                    Click="OpenLicense_Click"
                    ToolTip="WireSock lisansını aç" />

            <Button Grid.Column="1"
                    Margin="10,0,0,0"
                    Style="{StaticResource CommandButtonStyle}"
                    Content="WARP koşulları"
                    Click="OpenWarpTerms_Click"
                    ToolTip="Cloudflare WARP koşullarını aç" />

            <Button Grid.Column="3"
                    Margin="0,0,10,0"
                    Style="{StaticResource CommandButtonStyle}"
                    IsCancel="True"
                    Content="Vazgeç"
                    Click="Cancel_Click"
                    ToolTip="Kurulumu başlatmadan kapat" />

            <Button Grid.Column="4"
                    Style="{StaticResource PrimaryCommandButtonStyle}"
                    IsDefault="True"
                    Content="Kabul et ve kur"
                    Click="Accept_Click"
                    ToolTip="Onay ver ve kurulumu başlat" />
        </Grid>
    </Grid>
</Window>
