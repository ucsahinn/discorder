<Window x:Class="Discorder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Discorder"
        Width="760"
        Height="650"
        MinWidth="640"
        MinHeight="590"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
            <RowDefinition Height="112" />
            <RowDefinition Height="68" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Width="42"
                       Height="42"
                       Margin="0,0,14,0"
                       Source="Assets/discorder-logo.png"
                       Stretch="Uniform" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Discorder" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="Sadece Discord için VPN" />
                </StackPanel>

                <Border Grid.Column="2"
                        x:Name="StatusBadge"
                        Padding="12,6"
                        CornerRadius="4"
                        Background="#252A33"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot"
                                 Width="8"
                                 Height="8"
                                 Margin="0,0,8,0"
                                 Fill="{StaticResource SecondaryTextBrush}" />
                        <TextBlock x:Name="StatusLabel"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="KAPALI" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="36,28,36,26">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    x:Name="ToggleButton"
                    Width="214"
                    Height="214"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#1D2230"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="3"
                    Cursor="Hand"
                    Click="ToggleButton_Click"
                    AutomationProperties.Name="Discord tünelini aç veya kapat"
                    ToolTip="Discord tünelini aç veya kapat">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}">
                            <Ellipse x:Name="OuterRing"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="{TemplateBinding BorderThickness}" />
                            <Ellipse Margin="14"
                                     Fill="#171A21"
                                     Stroke="#343B4A"
                                     StrokeThickness="1" />
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="PowerIcon"
                                           HorizontalAlignment="Center"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="58"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="&#xE7E8;" />
                                <TextBlock x:Name="ToggleButtonLabel"
                                           Margin="0,14,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Text="BAĞLAN" />
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterRing"
                                        Property="Fill"
                                        Value="#242A3A" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="OuterRing"
                                        Property="StrokeThickness"
                                        Value="5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.58" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <TextBlock Grid.Row="1"
                       x:Name="StatusMessage"
                       Margin="0,20,0,0"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Text="Bağlantı kapalı" />

            <TextBlock Grid.Row="2"
                       x:Name="StatusDetail"
                       MaxWidth="590"
                       Margin="0,8,0,0"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="Hazır" />
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="TÜNEL KAPSAMI" />
                    <TextBlock Margin="0,7,0,0"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="Discord" />
                </StackPanel>

                <Border Grid.Column="1"
                        Height="48"
                        Background="{StaticResource BorderBrush}"
                        VerticalAlignment="Center" />

                <StackPanel Grid.Column="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="SİSTEM DNS" />
                    <TextBlock Margin="0,7,0,0"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="Değiştirilmez" />
                </StackPanel>

                <Border Grid.Column="3"
                        Height="48"
                        Background="{StaticResource BorderBrush}"
                        VerticalAlignment="Center" />

                <StackPanel Grid.Column="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="ÇALIŞMA MODU" />
                    <TextBlock Margin="0,7,0,0"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="Kullanıcı süreci" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Margin="0,0,10,0"
                    Style="{StaticResource CommandButtonStyle}"
                    Content="WireSock"
                    Click="OpenWireSock_Click"
                    ToolTip="WireSock VPN Client resmi sitesi" />

            <Button Grid.Column="1"
                    Style="{StaticResource CommandButtonStyle}"
                    Content="Tanılama"
                    Click="OpenDiagnostics_Click"
                    ToolTip="Yerel tanılama klasörünü aç" />

            <TextBlock Grid.Column="2"
                       Margin="18,0"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="v2.0.0" />

            <Button Grid.Column="3"
                    Style="{StaticResource CommandButtonStyle}"
                    Content="GitHub"
                    Click="OpenGitHub_Click"
                    ToolTip="Discorder kaynak deposunu aç" />
        </Grid>
    </Grid>
</Window>
