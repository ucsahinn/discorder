                                <GradientStop Color="#6417243B" Offset="0.55" />
                                <GradientStop Color="#4F101D31" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="34"
                                              Direction="270"
                                              Opacity="0.34"
                                              ShadowDepth="0"
                                              Color="#66D9FF" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="14,10"
                                    CornerRadius="7"
                                    Background="#33101D31"
                                    BorderBrush="#369CD4FF"
                                    BorderThickness="1">
                                <StackPanel>
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="DNS SUNUCUSU" />
                                <TextBlock x:Name="DnsSummary"
                                           Margin="0,6,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Text="Okunuyor" />
                                <TextBlock x:Name="DnsDetail"
