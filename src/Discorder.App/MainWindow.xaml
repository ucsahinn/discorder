<Window x:Class="Discorder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Discorder"
        Width="920"
        Height="720"
        MinWidth="780"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid ClipToBounds="True">
        <MediaElement x:Name="BackgroundVideo"
                      Source="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260606_154941_df1a96e1-a06f-450c-bd02-d863414cc1a0.mp4"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Stretch="UniformToFill"
                      Volume="0"
                      Opacity="0.58"
                      IsHitTestVisible="False"
                      Loaded="BackgroundVideo_Loaded"
                      MediaEnded="BackgroundVideo_MediaEnded"
                      MediaFailed="BackgroundVideo_MediaFailed" />

        <Rectangle IsHitTestVisible="False">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#9F050712" Offset="0" />
                    <GradientStop Color="#780B1730" Offset="0.42" />
                    <GradientStop Color="#7A241039" Offset="0.74" />
                    <GradientStop Color="#B0050712" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.42">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="#00121A30" Offset="0" />
                    <GradientStop Color="#2E5E6BFF" Offset="0.38" />
                    <GradientStop Color="#344DDCFF" Offset="0.62" />
                    <GradientStop Color="#00121A30" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="78" />
                <RowDefinition Height="*" />
                <RowDefinition Height="78" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#7A101827"
                    BorderBrush="#7E8B7DFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0"
                           Width="42"
                           Height="42"
                           Margin="0,0,14,0"
                           Source="Assets/discorder-logo.png"
                           Stretch="Uniform" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="Discorder" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Discord uygulaması için hazır, web modu isteğe bağlı" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            x:Name="StatusBadge"
                            Padding="13,7"
                            CornerRadius="5"
                            Background="#A6121B2D"
                            BorderBrush="#727EDBFF"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot"
                                     Width="8"
                                     Height="8"
                                     Margin="0,0,8,0"
                                     Fill="{StaticResource SecondaryTextBrush}" />
                            <TextBlock x:Name="StatusLabel"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="KAPALI" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="0.85*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#8F101827"
                        BorderBrush="#858B7DFF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="34">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="34"
                                          Direction="270"
                                          Opacity="0.34"
                                          ShadowDepth="12"
                                          Color="#17113A" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="ÖZEL TÜNEL" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="34"
                                       FontWeight="SemiBold"
                                       LineHeight="40"
                                       TextWrapping="Wrap"
                                       Text="Discord bağlantısını yönet" />
                        </StackPanel>

                        <Button Grid.Row="1"
                                x:Name="ToggleButton"
                                Width="228"
                                Height="228"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#661A2240"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="3"
                                Cursor="Hand"
                                Click="ToggleButton_Click"
                                AutomationProperties.Name="Discord tünelini aç veya kapat"
                                ToolTip="Discord tünelini aç veya kapat">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Width="{TemplateBinding Width}"
                                          Height="{TemplateBinding Height}">
                                        <Ellipse x:Name="OuterRing"
                                                 Stroke="{TemplateBinding BorderBrush}"
                                                 StrokeThickness="{TemplateBinding BorderThickness}">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush Center="0.42,0.34"
                                                                     GradientOrigin="0.32,0.24"
                                                                     RadiusX="0.86"
                                                                     RadiusY="0.86">
                                                    <GradientStop Color="#C52C315E" Offset="0" />
                                                    <GradientStop Color="#A11C2347" Offset="0.48" />
                                                    <GradientStop Color="#7A11182B" Offset="1" />
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="28"
                                                                  Direction="270"
                                                                  Opacity="0.55"
                                                                  ShadowDepth="0"
                                                                  Color="#5B63FF" />
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse Margin="15"
                                                 Stroke="#7866D9FF"
                                                 StrokeThickness="1">
                                            <Ellipse.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#9B131B32" Offset="0" />
                                                    <GradientStop Color="#783A2552" Offset="0.55" />
                                                    <GradientStop Color="#70203F55" Offset="1" />
                                                </LinearGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Ellipse Width="170"
                                                 Height="170"
                                                 Fill="Transparent"
                                                 Stroke="#4466D9FF"
                                                 StrokeThickness="1"
                                                 StrokeDashArray="2 5" />
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock x:Name="PowerIcon"
                                                       HorizontalAlignment="Center"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="62"
                                                       Foreground="{StaticResource AccentCyanBrush}"
                                                       Text="&#xE7E8;" />
                                            <TextBlock x:Name="ToggleButtonLabel"
                                                       Margin="0,15,0,0"
                                                       HorizontalAlignment="Center"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Text="BAĞLAN" />
                                        </StackPanel>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="OuterRing"
                                                    Property="Fill"
                                                    Value="#AA263056" />
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter TargetName="OuterRing"
                                                    Property="StrokeThickness"
                                                    Value="5" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.58" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                            <TextBlock x:Name="StatusMessage"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Bağlantı kapalı" />
                            <TextBlock x:Name="StatusDetail"
                                       MaxWidth="520"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Hazır" />
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2">
                   <Border Background="#C90D121C"
                            BorderBrush="#747EDBFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24"
                                              Direction="270"
                                              Opacity="0.22"
                                              ShadowDepth="8"
                                              Color="#11183A" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="TÜNEL KAPSAMI" />
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Discord web" />
                                    <TextBlock x:Name="BrowserAccessStatus"
                                               Margin="0,6,18,0"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               LineHeight="18"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Varsayılan mod. Yalnızca Discord uygulaması tünellenir." />
                                </StackPanel>

                                <CheckBox Grid.Column="1"
                                          x:Name="BrowserAccessToggle"
                                          Style="{StaticResource BrowserSwitchStyle}"
                                          VerticalAlignment="Top"
                                          Checked="BrowserAccessToggle_Changed"
                                          Unchecked="BrowserAccessToggle_Changed"
                                          ToolTip="Chrome, Edge, Firefox, Brave, Opera ve Vivaldi ile Discord web tünelini aç" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,18,0,0"
                            Background="#80101827"
                            BorderBrush="#5F66D9FF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="SİSTEM DNS" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Değiştirilmez" />
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="ÇALIŞMA MODU" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Kullanıcı süreci" />
                            </StackPanel>

                            <StackPanel Grid.Row="4">
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="KAPANIŞ" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Discord kilitlenir" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="#7A101827"
                    BorderBrush="#7E8B7DFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Margin="0,0,10,0"
                            Height="46"
                            VerticalAlignment="Center"
                            Style="{StaticResource CommandButtonStyle}"
                            Content="WireSock"
                            Click="OpenWireSock_Click"
                            ToolTip="WireSock VPN Client resmi sitesi" />

                    <Button Grid.Column="1"
                            Height="46"
                            VerticalAlignment="Center"
                            Style="{StaticResource CommandButtonStyle}"
                            Content="Tanılama"
                            Click="OpenDiagnostics_Click"
                            ToolTip="Yerel tanılama klasörünü aç" />

                    <TextBlock Grid.Column="2"
                               Margin="18,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="v2.0.0" />

                    <Button Grid.Column="3"
                            Height="46"
                            VerticalAlignment="Center"
                            Style="{StaticResource CommandButtonStyle}"
                            Content="GitHub"
                            Click="OpenGitHub_Click"
                            ToolTip="Discorder kaynak deposunu aç" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
