<Window x:Class="Discorder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Discorder"
        Width="1180"
        Height="720"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid ClipToBounds="True">
        <MediaElement x:Name="BackgroundVideo"
                      Source="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260606_154941_df1a96e1-a06f-450c-bd02-d863414cc1a0.mp4"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Stretch="UniformToFill"
                      Volume="0"
                      Opacity="1"
                      IsHitTestVisible="False"
                      Loaded="BackgroundVideo_Loaded"
                      MediaEnded="BackgroundVideo_MediaEnded"
                      MediaFailed="BackgroundVideo_MediaFailed" />

        <Rectangle IsHitTestVisible="False">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#90040710" Offset="0" />
                    <GradientStop Color="#5A071120" Offset="0.38" />
                    <GradientStop Color="#24071120" Offset="0.68" />
                    <GradientStop Color="#28040710" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.42">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.72,0.42"
                                     GradientOrigin="0.72,0.38"
                                     RadiusX="0.70"
                                     RadiusY="0.78">
                    <GradientStop Color="#00121A30" Offset="0" />
                    <GradientStop Color="#1EFF3F75" Offset="0.38" />
                    <GradientStop Color="#225EEBFF" Offset="0.66" />
                    <GradientStop Color="#00050712" Offset="1" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.55">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                    <GradientStop Color="#85040710" Offset="0" />
                    <GradientStop Color="#22040710" Offset="0.42" />
                    <GradientStop Color="#00040710" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.14">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.26,0.44"
                                     GradientOrigin="0.22,0.36"
                                     RadiusX="0.52"
                                     RadiusY="0.72">
                    <GradientStop Color="#7E61F6FF" Offset="0" />
                    <GradientStop Color="#2639E8FF" Offset="0.58" />
                    <GradientStop Color="#00050712" Offset="1" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="74" />
                <RowDefinition Height="*" />
                <RowDefinition Height="72" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#47101827"
                    BorderBrush="#8A8EA7FF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18,0"
                    MaxWidth="1120">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28"
                                      Direction="270"
                                      Opacity="0.24"
                                      ShadowDepth="0"
                                      Color="#63D9FF" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0"
                           Width="42"
                           Height="42"
                           Margin="0,0,14,0"
                           Source="Assets/discorder-logo.png"
                           Stretch="Uniform" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="Discorder" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Discord uygulaması için hazır, web modu isteğe bağlı" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            x:Name="StatusBadge"
                            Padding="14,8"
                            CornerRadius="5"
                            Background="#78101A2D"
                            BorderBrush="#9378E5FF"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot"
                                     Width="8"
                                     Height="8"
                                     Margin="0,0,8,0"
                                     Fill="{StaticResource SecondaryTextBrush}" />
                            <TextBlock x:Name="StatusLabel"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="KAPALI" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="510" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#59101827"
                        BorderBrush="#A184E8FF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="32,30"
                        MaxHeight="470"
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="54"
                                          Direction="270"
                                          Opacity="0.45"
                                          ShadowDepth="0"
                                          Color="#66D9FF" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="ÖZEL TÜNEL" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="36"
                                       FontWeight="SemiBold"
                                       LineHeight="41"
                                       TextWrapping="Wrap"
                                       Text="Discord bağlantısını yönet" />
                        </StackPanel>

                        <Button Grid.Row="1"
                                x:Name="ToggleButton"
                                Width="218"
                                Height="218"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#661A2240"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="3"
                                Cursor="Hand"
                                Click="ToggleButton_Click"
                                AutomationProperties.AutomationId="TunnelToggleButton"
                                AutomationProperties.Name="Discord tünelini aç veya kapat"
                                ToolTip="Discord tünelini aç veya kapat">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Width="{TemplateBinding Width}"
                                          Height="{TemplateBinding Height}">
                                        <Ellipse x:Name="OuterRing"
                                                 Stroke="{TemplateBinding BorderBrush}"
                                                 StrokeThickness="{TemplateBinding BorderThickness}">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush Center="0.42,0.34"
                                                                     GradientOrigin="0.32,0.24"
                                                                     RadiusX="0.86"
                                                                     RadiusY="0.86">
                                                    <GradientStop Color="#C52C315E" Offset="0" />
                                                    <GradientStop Color="#B02F2D66" Offset="0.42" />
                                                    <GradientStop Color="#8D152547" Offset="0.72" />
                                                    <GradientStop Color="#7A11182B" Offset="1" />
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="58"
                                                                  Direction="270"
                                                                  Opacity="0.95"
                                                                  ShadowDepth="0"
                                                                  Color="#56F07B" />
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse Margin="14"
                                                 Stroke="#A0B9F8FF"
                                                 StrokeThickness="1.2">
                                            <Ellipse.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#BE16243B" Offset="0" />
                                                    <GradientStop Color="#9C24425C" Offset="0.55" />
                                                    <GradientStop Color="#833A5F65" Offset="1" />
                                                </LinearGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Ellipse Width="178"
                                                 Height="178"
                                                 Fill="Transparent"
                                                 Stroke="#7A66D9FF"
                                                 StrokeThickness="1"
                                                 StrokeDashArray="2 5" />
                                        <Ellipse Width="124"
                                                 Height="124"
                                                 Fill="#2246F07B"
                                                 Stroke="#6C56F07B"
                                                 StrokeThickness="1" />
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock x:Name="PowerIcon"
                                                       HorizontalAlignment="Center"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="62"
                                                       Foreground="{StaticResource AccentCyanBrush}"
                                                       Text="&#xE7E8;">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect BlurRadius="18"
                                                                      Direction="270"
                                                                      Opacity="0.86"
                                                                      ShadowDepth="0"
                                                                      Color="#56F07B" />
                                                </TextBlock.Effect>
                                            </TextBlock>
                                            <TextBlock x:Name="ToggleButtonLabel"
                                                       Margin="0,15,0,0"
                                                       HorizontalAlignment="Center"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Text="BAĞLAN" />
                                        </StackPanel>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="OuterRing"
                                                    Property="Fill"
                                                    Value="#9C253E54" />
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter TargetName="OuterRing"
                                                    Property="StrokeThickness"
                                                    Value="5" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.58" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                            <TextBlock x:Name="StatusMessage"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="19"
                                       FontWeight="SemiBold"
                                       Text="Bağlantı kapalı" />
                            <TextBlock x:Name="StatusDetail"
                                       MaxWidth="520"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Hazır" />
                        </StackPanel>

                        <Border Grid.Row="3"
                                Margin="0,22,0,0"
                                Padding="16,14"
                                Background="#39132033"
                                BorderBrush="#5F8EA7FF"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="StageProgressLabel"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="Süreç hazır" />
                                    <TextBlock Grid.Column="1"
                                               x:Name="StageProgressPercent"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="8%" />
                                </Grid>

                                <ProgressBar x:Name="StageProgressBar"
                                             Margin="0,10,0,0"
                                             Style="{StaticResource StageProgressStyle}"
                                             Value="8" />

                                <UniformGrid Margin="0,12,0,0"
                                             Columns="4">
                                    <TextBlock x:Name="StageStepLock"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Kilit" />
                                    <TextBlock x:Name="StageStepSetup"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Kurulum" />
                                    <TextBlock x:Name="StageStepProfile"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Profil" />
                                    <TextBlock x:Name="StageStepTunnel"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Tünel" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="28,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            HorizontalAlignment="Right"
                            Width="560"
                            Background="#42101827"
                            BorderBrush="#8D7EDBFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22,20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="30"
                                              Direction="270"
                                              Opacity="0.34"
                                              ShadowDepth="0"
                                              Color="#4C72FF" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="TÜNEL KAPSAMI" />
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Discord web" />
                                    <TextBlock x:Name="BrowserAccessStatus"
                                               Margin="0,6,18,0"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               LineHeight="18"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Varsayılan mod. Yalnızca Discord uygulaması tünellenir." />
                                </StackPanel>

                                <CheckBox Grid.Column="1"
                                          x:Name="BrowserAccessToggle"
                                          Style="{StaticResource BrowserSwitchStyle}"
                                          VerticalAlignment="Top"
                                          Checked="BrowserAccessToggle_Changed"
                                          Unchecked="BrowserAccessToggle_Changed"
                                          ToolTip="Chrome, Edge, Firefox, Brave, Opera ve Vivaldi ile Discord web tünelini aç" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="560"
                            Background="#3C101827"
                            BorderBrush="#7478E5FF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20,18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="34"
                                              Direction="270"
                                              Opacity="0.30"
                                              ShadowDepth="0"
                                              Color="#63D9FF" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="İŞLETİM AYARLARI" />

                            <Grid Grid.Row="1"
                                  Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Margin="0,0,18,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="Arka planda çalış" />
                                    <TextBlock Grid.Row="1"
                                               x:Name="RunInBackgroundStatus"
                                               Margin="0,5,0,10"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               LineHeight="17"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Pencere kapanınca güvenli biçimde kapanır." />
                                    <CheckBox Grid.Row="2"
                                              x:Name="RunInBackgroundToggle"
                                              Style="{StaticResource BrowserSwitchStyle}"
                                              HorizontalAlignment="Left"
                                              Checked="RunInBackgroundToggle_Changed"
                                              Unchecked="RunInBackgroundToggle_Changed"
                                              ToolTip="Pencere kapanınca Discorder'ı bildirim alanında çalıştır" />
                                </Grid>

                                <Rectangle Grid.Column="1"
                                           Width="1"
                                           Fill="#35FFFFFF" />

                                <Grid Grid.Column="2"
                                      Margin="18,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="Windows başlangıcı" />
                                    <TextBlock Grid.Row="1"
                                               x:Name="StartupStatus"
                                               Margin="0,5,0,10"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               LineHeight="17"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Oturum açılışında başlamaz." />
                                    <CheckBox Grid.Row="2"
                                              x:Name="StartupToggle"
                                              Style="{StaticResource BrowserSwitchStyle}"
                                              HorizontalAlignment="Left"
                                              Checked="StartupToggle_Changed"
                                              Unchecked="StartupToggle_Changed"
                                              ToolTip="Discorder'ı Windows oturumu açılınca başlat" />
                                </Grid>

                                <Rectangle Grid.Column="3"
                                           Width="1"
                                           Fill="#35FFFFFF" />

                                <Grid Grid.Column="4"
                                      Margin="18,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="Arka plan videosu" />
                                    <TextBlock Grid.Row="1"
                                               x:Name="BackgroundVideoStatus"
                                               Margin="0,5,0,10"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               LineHeight="17"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Video açık, sahne canlı." />
                                    <CheckBox Grid.Row="2"
                                              x:Name="BackgroundVideoToggle"
                                              Style="{StaticResource BrowserSwitchStyle}"
                                              HorizontalAlignment="Left"
                                              Checked="BackgroundVideoToggle_Changed"
                                              Unchecked="BackgroundVideoToggle_Changed"
                                              ToolTip="Arka plan videosunu aç veya kapat" />
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            HorizontalAlignment="Right"
                            Width="560"
                            Background="#3A101827"
                            BorderBrush="#7473DBFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20,18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="28"
                                              Direction="270"
                                              Opacity="0.26"
                                              ShadowDepth="0"
                                              Color="#66D9FF" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="SİSTEM DNS" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Değiştirilmez" />
                            </StackPanel>

                            <Rectangle Grid.Column="1"
                                       Width="1"
                                       Fill="#3DFFFFFF" />

                            <StackPanel Grid.Column="2" Margin="20,0">
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="ÇALIŞMA MODU" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Kullanıcı süreci" />
                            </StackPanel>

                            <Rectangle Grid.Column="3"
                                       Width="1"
                                       Fill="#3DFFFFFF" />

                            <StackPanel Grid.Column="4" Margin="20,0,0,0">
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="KAPANIŞ" />
                                <TextBlock x:Name="CloseBehaviorSummary"
                                           Margin="0,6,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Discord kilitlenir" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Background="#42101827"
                    BorderBrush="#8A8B7DFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,0"
                    MaxWidth="1120">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24"
                                      Direction="270"
                                      Opacity="0.22"
                                      ShadowDepth="0"
                                      Color="#63D9FF" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Margin="0,0,10,0"
                            Height="46"
                            VerticalAlignment="Center"
                            Style="{StaticResource CommandButtonStyle}"
                            Content="WireSock"
                            Click="OpenWireSock_Click"
                            ToolTip="WireSock VPN Client resmi sitesi" />

                    <Button Grid.Column="1"
                            Height="46"
                            VerticalAlignment="Center"
                            Style="{StaticResource CommandButtonStyle}"
                            Content="Tanılama"
                            Click="OpenDiagnostics_Click"
                            ToolTip="Yerel tanılama klasörünü aç" />

                    <Button Grid.Column="2"
                            x:Name="RepairButton"
                            Margin="10,0,0,0"
                            Height="46"
                            VerticalAlignment="Center"
                            Style="{StaticResource CommandButtonStyle}"
                            Content="Sıfırla"
                            Click="Repair_Click"
                            ToolTip="Profil, wgcf, kurucu önbelleği ve logları yeniden üretilecek hale getir" />

                    <Button Grid.Column="3"
                            x:Name="CleanUninstallButton"
                            Margin="10,0,0,0"
                            Height="46"
                            VerticalAlignment="Center"
                            Style="{StaticResource DangerCommandButtonStyle}"
                            Content="Temiz kaldır"
                            Click="CleanUninstall_Click"
                            ToolTip="Discorder kilitlerini geri al, yerel Discorder verisini sil ve uygulamayı kapat" />

                    <TextBlock Grid.Column="4"
                               Margin="18,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="v2.0.4" />

                    <Button Grid.Column="5"
                            Height="46"
                            VerticalAlignment="Center"
                            Style="{StaticResource CommandButtonStyle}"
                            Content="GitHub"
                            Click="OpenGitHub_Click"
                            ToolTip="Discorder kaynak deposunu aç" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
