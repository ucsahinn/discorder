<Window x:Class="Discorder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Discorder"
        Width="1320"
        Height="780"
        MinWidth="1320"
        MinHeight="780"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid ClipToBounds="True">
        <MediaElement x:Name="BackgroundVideo"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Stretch="UniformToFill"
                      Volume="0"
                      Opacity="0.88"
                      IsHitTestVisible="False"
                      Loaded="BackgroundVideo_Loaded"
                      MediaEnded="BackgroundVideo_MediaEnded"
                      MediaFailed="BackgroundVideo_MediaFailed" />

        <Rectangle IsHitTestVisible="False">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#D0040710" Offset="0" />
                    <GradientStop Color="#98091322" Offset="0.34" />
                    <GradientStop Color="#5A071120" Offset="0.72" />
                    <GradientStop Color="#64040710" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.24">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.72,0.42"
                                     GradientOrigin="0.72,0.38"
                                     RadiusX="0.70"
                                     RadiusY="0.78">
                    <GradientStop Color="#00121A30" Offset="0" />
                    <GradientStop Color="#1EFF3F75" Offset="0.38" />
                    <GradientStop Color="#225EEBFF" Offset="0.66" />
                    <GradientStop Color="#00050712" Offset="1" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.86">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                    <GradientStop Color="#A7040710" Offset="0" />
                    <GradientStop Color="#3C040710" Offset="0.42" />
                    <GradientStop Color="#00040710" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.18">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.26,0.44"
                                     GradientOrigin="0.22,0.36"
                                     RadiusX="0.52"
                                     RadiusY="0.72">
                    <GradientStop Color="#7E61F6FF" Offset="0" />
                    <GradientStop Color="#2639E8FF" Offset="0.58" />
                    <GradientStop Color="#00050712" Offset="1" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.16">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#307DEBFF" Offset="0" />
                    <GradientStop Color="#00040710" Offset="0.32" />
                    <GradientStop Color="#185DFF92" Offset="0.68" />
                    <GradientStop Color="#00040710" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="76" />
                <RowDefinition Height="*" />
                <RowDefinition Height="74" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource PremiumLineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18,0"
                    MaxWidth="1264">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#9B0C1728" Offset="0" />
                        <GradientStop Color="#7817253C" Offset="0.54" />
                        <GradientStop Color="#64101D31" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="36"
                                      Direction="270"
                                      Opacity="0.42"
                                      ShadowDepth="0"
                                      Color="#63D9FF" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="54"
                            Height="54"
                            Margin="0,0,16,0"
                            CornerRadius="8"
                            BorderBrush="#B77DEBFF"
                            BorderThickness="1"
                            RenderTransformOrigin="0.5,0.5"
                            VerticalAlignment="Center">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="LogoScale"
                                                ScaleX="1"
                                                ScaleY="1" />
                                <RotateTransform x:Name="LogoTilt"
                                                 Angle="0" />
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoTilt"
                                                                       Storyboard.TargetProperty="Angle">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.45" Value="-3" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.7" Value="3" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.95" Value="-1.5" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:2.2" Value="0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:4.6" Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoScale"
                                                                       Storyboard.TargetProperty="ScaleX">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.45" Value="1.035" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.7" Value="1.015" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:2.2" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:4.6" Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoScale"
                                                                       Storyboard.TargetProperty="ScaleY">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.45" Value="1.035" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.7" Value="1.015" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:2.2" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:4.6" Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <Border.Background>
                            <RadialGradientBrush Center="0.45,0.38"
                                                 GradientOrigin="0.32,0.24"
                                                 RadiusX="0.85"
                                                 RadiusY="0.85">
                                <GradientStop Color="#5A7DEBFF" Offset="0" />
                                <GradientStop Color="#2A5DFF92" Offset="0.45" />
                                <GradientStop Color="#80101D31" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20"
                                              Direction="270"
                                              Opacity="0.58"
                                              ShadowDepth="0"
                                              Color="#7DEBFF" />
                        </Border.Effect>
                        <Image Width="42"
                               Height="42"
                               Source="Assets/discorder-mark.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="Discorder" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Çalışma modu hazır. Tarayıcı modu isteğe bağlı." />
                    </StackPanel>

                    <Border Grid.Column="2"
                            x:Name="StatusBadge"
                            Padding="14,8"
                            CornerRadius="7"
                            Background="#8A101A2D"
                            BorderBrush="#B77DEBFF"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot"
                                     Width="8"
                                     Height="8"
                                     Margin="0,0,8,0"
                                     Fill="{StaticResource SecondaryTextBrush}" />
                            <TextBlock x:Name="StatusLabel"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="KAPALI" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="560" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="#C49CD4FF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="30,22"
                        MaxHeight="536"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#A20B1422" Offset="0" />
                            <GradientStop Color="#7E17243B" Offset="0.52" />
                            <GradientStop Color="#68101D31" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="64"
                                          Direction="270"
                                          Opacity="0.62"
                                          ShadowDepth="0"
                                          Color="#66D9FF" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                x:Name="ToggleButton"
                                Width="286"
                                Height="286"
                                Margin="0,-8,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#761A2240"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="3"
                                Cursor="Hand"
                                Click="ToggleButton_Click"
                                AutomationProperties.AutomationId="TunnelToggleButton"
                                AutomationProperties.Name="Discord bağlantısını aç veya kapat"
                                ToolTip="Discord bağlantısını aç veya kapat">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Width="{TemplateBinding Width}"
                                          Height="{TemplateBinding Height}">
                                        <Ellipse x:Name="OuterRing"
                                                 Margin="11"
                                                 Stroke="{TemplateBinding BorderBrush}"
                                                 StrokeThickness="{TemplateBinding BorderThickness}">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush Center="0.42,0.34"
                                                                     GradientOrigin="0.32,0.24"
                                                                     RadiusX="0.86"
                                                                     RadiusY="0.86">
                                                    <GradientStop Color="#D633426A" Offset="0" />
                                                    <GradientStop Color="#C329315A" Offset="0.34" />
                                                    <GradientStop Color="#95152547" Offset="0.72" />
                                                    <GradientStop Color="#8210182B" Offset="1" />
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="42"
                                                                  Direction="270"
                                                                  Opacity="0.95"
                                                                  ShadowDepth="0"
                                                                  Color="#56F07B" />
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse Width="264"
                                                 Height="264"
                                                 Stroke="#45FFFFFF"
                                                 StrokeThickness="1" />
                                        <Ellipse Margin="31"
                                                 Stroke="#B87DEBFF"
                                                 StrokeThickness="1.4">
                                            <Ellipse.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#C916243B" Offset="0" />
                                                    <GradientStop Color="#A724425C" Offset="0.55" />
                                                    <GradientStop Color="#8B3A5F65" Offset="1" />
                                                </LinearGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Ellipse x:Name="StateRing"
                                                 Width="218"
                                                 Height="218"
                                                 Fill="Transparent"
                                                 Stroke="#8F7DEBFF"
                                                 StrokeThickness="1"
                                                 StrokeDashArray="3 7" />
                                        <Ellipse Width="162"
                                                 Height="162"
                                                 Fill="Transparent"
                                                 Stroke="#4CF5F7FB"
                                                 StrokeThickness="1" />
                                        <Ellipse x:Name="CoreGlow"
                                                 Width="134"
                                                 Height="134"
                                                 Stroke="#785DFF92"
                                                 StrokeThickness="1.2">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush Center="0.46,0.38"
                                                                     GradientOrigin="0.34,0.25"
                                                                     RadiusX="0.82"
                                                                     RadiusY="0.82">
                                                    <GradientStop Color="#3E7DEBFF" Offset="0" />
                                                    <GradientStop Color="#275DFF92" Offset="0.48" />
                                                    <GradientStop Color="#14040710" Offset="1" />
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock x:Name="PowerIcon"
                                                       HorizontalAlignment="Center"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="66"
                                                       Foreground="{StaticResource AccentCyanBrush}"
                                                       Text="&#xE7E8;">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect BlurRadius="18"
                                                                      Direction="270"
                                                                      Opacity="0.86"
                                                                      ShadowDepth="0"
                                                                      Color="#5DFF92" />
                                                </TextBlock.Effect>
                                            </TextBlock>
                                            <TextBlock x:Name="ToggleButtonLabel"
                                                       Margin="0,14,0,0"
                                                       HorizontalAlignment="Center"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Text="BAĞLAN" />
                                        </StackPanel>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="OuterRing"
                                                    Property="Fill"
                                                    Value="#9C253E54" />
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter TargetName="OuterRing"
                                                    Property="StrokeThickness"
                                                    Value="5" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.58" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <StackPanel Grid.Row="1"
                                    Margin="0,2,0,0"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="StatusMessage"
                                       MaxWidth="520"
                                       MaxHeight="58"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="19"
                                       FontWeight="SemiBold"
                                       Text="Bağlantı kapalı" />
                            <TextBlock x:Name="StatusDetail"
                                       MaxWidth="520"
                                       MaxHeight="42"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Hazır" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Margin="0,12,0,0"
                                Padding="16,12"
                                BorderBrush="#5F8EA7FF"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#56101D31" Offset="0" />
                                    <GradientStop Color="#3E19314A" Offset="0.55" />
                                    <GradientStop Color="#31101D31" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="StageProgressLabel"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="Discorder Bağlı Değil" />
                                    <TextBlock Grid.Column="1"
                                               x:Name="StageProgressPercent"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="8%" />
                                </Grid>

                                <ProgressBar x:Name="StageProgressBar"
                                             Margin="0,10,0,0"
                                             Style="{StaticResource StageProgressStyle}"
                                             Value="8" />

                                <UniformGrid Margin="0,10,0,0"
                                             Columns="4">
                                    <TextBlock x:Name="StageStepLock"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                      Text="Bağlantı" />
                                    <TextBlock x:Name="StageStepSetup"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Kurulum" />
                                    <TextBlock x:Name="StageStepProfile"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Profil" />
                                    <TextBlock x:Name="StageStepTunnel"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Bağlantı" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="28,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            HorizontalAlignment="Right"
                            Width="650"
                            BorderBrush="#B58EC8FF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8E0B1422" Offset="0" />
                                <GradientStop Color="#70213A53" Offset="0.58" />
                                <GradientStop Color="#55101D31" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="34"
                                              Direction="270"
                                              Opacity="0.40"
                                              ShadowDepth="0"
                                              Color="#4C72FF" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Çalışma modu" />
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,8,0"
                                                   FontFamily="Segoe UI Emoji"
                                                   FontSize="17"
                                                   Text="🌐" />
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Tarayıcı modu" />
                                    </StackPanel>
                                    <TextBlock x:Name="BrowserAccessStatus"
                                               Margin="0,6,18,0"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               LineHeight="18"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Discord web erişimini tarayıcıda da kullan." />
                                </StackPanel>

                                <CheckBox Grid.Column="1"
                                          x:Name="BrowserAccessToggle"
                                          Style="{StaticResource BrowserSwitchStyle}"
                                          VerticalAlignment="Top"
                                          Checked="BrowserAccessToggle_Changed"
                                          Unchecked="BrowserAccessToggle_Changed"
                                          ToolTip="Discord web'i tarayıcıda da kullan"
                                          AutomationProperties.Name="Tarayıcı modunu aç veya kapat" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="650"
                            BorderBrush="#B58EC8FF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20,18">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#920B1422" Offset="0" />
                                <GradientStop Color="#7A17243B" Offset="0.45" />
                                <GradientStop Color="#5F101D31" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40"
                                              Direction="270"
                                              Opacity="0.38"
                                              ShadowDepth="0"
                                              Color="#63D9FF" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="İŞLETİM MERKEZİ" />

                            <Grid Grid.Row="1"
                                  Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Margin="0,0,18,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,7,0"
                                                   FontFamily="Segoe UI Emoji"
                                                   FontSize="14"
                                                   Text="🌙" />
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="Arka planda çalış" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="1"
                                               x:Name="RunInBackgroundStatus"
                                               Margin="0,5,0,10"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               LineHeight="17"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Pencere kapanınca bildirim alanında kalmaz." />
                                    <CheckBox Grid.Row="2"
                                              x:Name="RunInBackgroundToggle"
                                              Style="{StaticResource BrowserSwitchStyle}"
                                              HorizontalAlignment="Left"
                                              Checked="RunInBackgroundToggle_Changed"
                                              Unchecked="RunInBackgroundToggle_Changed"
                                              ToolTip="Pencere kapanınca çalışmaya devam et"
                                              AutomationProperties.Name="Arka planda çalışmayı aç veya kapat" />
                                </Grid>

                                <Rectangle Grid.Column="1"
                                           Width="1"
                                           Fill="#35FFFFFF" />

                                <Grid Grid.Column="2"
                                      Margin="18,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Margin="0,0,7,0"
                                                   FontFamily="Segoe UI Emoji"
                                                   FontSize="14"
                                                   Text="🚀" />
                                        <TextBlock Grid.Column="1"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18"
                                                   Text="Windows açılışında çalıştır" />
                                    </Grid>
                                    <TextBlock Grid.Row="1"
                                               x:Name="StartupStatus"
                                               Margin="0,5,0,10"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               LineHeight="17"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Windows açılışında çalıştır" />
                                    <CheckBox Grid.Row="2"
                                              x:Name="StartupToggle"
                                              Style="{StaticResource BrowserSwitchStyle}"
                                              HorizontalAlignment="Left"
                                              Checked="StartupToggle_Changed"
                                              Unchecked="StartupToggle_Changed"
                                              ToolTip="Discorder'ı Windows açılışında başlat"
                                              AutomationProperties.Name="Windows açılışında çalıştırmayı aç veya kapat" />
                                </Grid>

                                <Rectangle Grid.Column="3"
                                           Width="1"
                                           Fill="#35FFFFFF" />

                                <Grid Grid.Column="4"
                                      Margin="18,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,7,0"
                                                   FontFamily="Segoe UI Emoji"
                                                   FontSize="14"
                                                   Text="🧾" />
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="Tanılama" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="1"
                                               x:Name="DiagnosticsStatus"
                                               Margin="0,5,0,10"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               LineHeight="17"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Bağlantı sorunlarını incelemek için rapor hazırla" />
                                    <Border Grid.Row="2"
                                            HorizontalAlignment="Left"
                                            Padding="12,6"
                                            CornerRadius="6"
                                            Background="#70305A65"
                                            BorderBrush="{StaticResource PremiumLineBrush}"
                                            BorderThickness="1">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="Hazır" />
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            HorizontalAlignment="Right"
                            Width="650"
                            BorderBrush="#B58EC8FF"
                            BorderThickness="1"
                            CornerRadius="8"
